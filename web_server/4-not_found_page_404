#!/usr/bin/env bash
# Configures Nginx with a custom 404 page containing "Ceci n'est pas une page"

sudo apt-get update -y
sudo apt-get -y install nginx

echo "Holberton School" | sudo tee /var/www/html/index.html > /dev/null

# Create custom 404 page
echo "Ceci n'est pas une page" | sudo tee /var/www/html/404.html > /dev/null

# Write clean config to both sites-available and sites-enabled
sudo tee /etc/nginx/sites-available/default > /dev/null <<'NGINX'
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.html index.htm;

    server_name _;

    error_page 404 /404.html;
    location = /404.html {
        internal;
    }

    location /redirect_me {
        return 301 https://www.youtube.com/;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}
NGINX

sudo cp /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default

sudo nginx -t && sudo service nginx restart

#!/usr/bin/env bash
# 3-redirection: Configure Ubuntu machine with Nginx 301 redirect

set -e

# Variables
TARGET_URL="https://www.youtube.com/watch?v=QH2-TGUlwu4"
NGINX_CONF="/etc/nginx/sites-available/default"
REDIRECT_PATH="/redirect_me"

# 1. Update packages and install Nginx if not installed
sudo apt update -y
sudo apt install -y nginx

# 2. Backup existing config
sudo cp "$NGINX_CONF" "${NGINX_CONF}.bak_$(date +%F_%T)"

# 3. Remove existing redirect location block if exists
sudo sed -i "/location $REDIRECT_PATH {/,/}/d" "$NGINX_CONF"

# 4. Add new redirect location block at the end of server block
sudo sed -i "/server_name _;/a \\
    location $REDIRECT_PATH {\\
        return 301 $TARGET_URL;\\
    }" "$NGINX_CONF"

# 5. Test Nginx configuration
sudo nginx -t

# 6. Reload Nginx
sudo systemctl reload nginx

echo "Redirect from $REDIRECT_PATH to $TARGET_URL configured successfully!"
